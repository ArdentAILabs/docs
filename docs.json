{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ardent",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "redirects": [
    {
      "source": "/cli-reference",
      "destination": "/cli/overview"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Using Ardent",
            "pages": [
              "workflows/ai-agents",
              "workflows/local-dev",
              "workflows/ci-cd",
              "workflows/regression-testing"
            ]
          },
          {
            "group": "Connectors",
            "pages": [
              {
                "group": "PostgreSQL",
                "collapsed": false,
                "pages": [
                  "connectors/supabase",
                  "connectors/rds",
                  "connectors/planetscale",
                  "connectors/self-hosted"
                ]
              }
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "architecture",
              "security"
            ]
          },
          {
            "group": "Support",
            "pages": [
              "faq",
              "contact"
            ]
          }
        ]
      },
      {
        "tab": "CLI / API reference",
        "groups": [
          {
            "group": "CLI",
            "pages": [
              "cli/overview",
              "cli/auth",
              "cli/projects",
              "cli/connectors",
              "cli/branches",
              "cli/settings",
              "cli/org"
            ]
          },
          {
            "group": "API",
            "pages": ["api-reference"]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:vikram@tryardent.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Log in",
      "href": "https://app.tryardent.com"
    }
  },
  "footer": {}
}
